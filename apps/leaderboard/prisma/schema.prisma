generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Score {
  id         String   @id @default(cuid())
  gameSlug   String
  playerName String
  score      Int
  createdAt  DateTime @default(now())

  @@index([gameSlug, score])
  @@index([playerName, createdAt])
}
