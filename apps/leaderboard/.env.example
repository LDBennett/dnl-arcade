# Supabase connection strings — dashboard's "Connect" panel has three tabs
# (Direct connection, Transaction pooler, Session pooler); use the pooler ones
# below since the raw direct-connection host requires IPv6.
# Transaction pooler (port 6543, pgbouncer=true) — used at runtime.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-1-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (port 5432) — used only by `prisma migrate` (migrations don't
# work reliably through the transaction pooler).
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-1-xx-xxxx-1.pooler.supabase.com:5432/postgres"
